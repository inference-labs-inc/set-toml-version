{
  "name": "set-toml-version",
  "version": "1.0.0",
  "description": "GitHub Action to update version fields in pyproject.toml and Cargo.toml files",
  "author": "Inference Labs Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inference-labs-inc/set-toml-version.git"
  },
  "keywords": [
    "github-action",
    "toml",
    "version",
    "pyproject",
    "cargo",
    "semver",
    "release"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "ncc build index.js -o dist",
    "test": "node --test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "semver": "^7.6.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.2",
    "husky": "^9.1.7",
    "prettier": "^3.4.2"
  }
}
